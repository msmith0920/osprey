# The event-dispatcher and dispatch-worker share one locally-built image
# (see ./Dockerfile). `osprey deploy up` builds it on first run; subsequent
# runs reuse the local tag. To use a prebuilt/published image instead, set
# OSPREY_DISPATCH_IMAGE (e.g. OSPREY_DISPATCH_IMAGE=my-registry/osprey-dispatch:dev).
# Use `osprey deploy up --dev` to bake in your local osprey checkout (incl.
# unreleased code) via a wheel; otherwise the image installs osprey from PyPI.

services:
  event-dispatcher:
    image: ${OSPREY_DISPATCH_IMAGE:-{{ services.event_dispatcher.image | default('osprey-dispatch:local') }}}
    build:
      # With multiple `-f` compose files, ALL relative paths (build contexts and
      # bind mounts alike) resolve against the FIRST file's dir — the compose
      # project directory, build/services/ — not this file's own subdir. So the
      # context is ./event_dispatcher, matching the volume-path convention below.
      context: ./event_dispatcher
      dockerfile: Dockerfile
      args:
        OSPREY_VERSION: "{{ osprey_version | default('') }}"
    container_name: osprey-event-dispatcher
    command: ["python", "-m", "osprey.dispatch"]
    labels:
      osprey.project.name: "{{ osprey_labels.project_name }}"
      osprey.project.root: "{{ osprey_labels.project_root }}"
      osprey.deployed.at: "{{ osprey_labels.deployed_at }}"
    restart: unless-stopped
    ports:
      - "{{ deployment.bind_address | default('127.0.0.1') }}:{{ services.event_dispatcher.port | default(8020) }}:{{ services.event_dispatcher.port | default(8020) }}"
    environment:
      # FastMCP reads transport/host/port from FASTMCP_* (env prefix "FASTMCP_").
      # `python -m osprey.dispatch` -> run_mcp_server -> server.run() honors these;
      # plain MCP_* vars are NOT read by the dispatcher entrypoint.
      FASTMCP_TRANSPORT: http
      FASTMCP_HOST: 0.0.0.0
      FASTMCP_PORT: "{{ services.event_dispatcher.port | default(8020) }}"
      EVENT_DISPATCHER_TOKEN: ${EVENT_DISPATCHER_TOKEN:-dev-token}
      DISPATCH_WORKER_TOKEN: ${DISPATCH_WORKER_TOKEN:-dev-token}
      TRIGGERS_YML: /app/triggers.yml
      OSPREY_FACILITY_NAME: "{{ services.event_dispatcher.facility_name | default('') }}"
      PV_STRIP_PREFIX: "{{ services.event_dispatcher.pv_strip_prefix | default('') }}"
      TZ: {{ system.timezone }}
    # Bind-mount sources are relative to the compose *project directory*
    # (build/services/), which is the first -f file's location — not this
    # service's subdir — so they must be prefixed with event_dispatcher/.
    volumes:
      - ./event_dispatcher/triggers.yml:/app/triggers.yml:ro
      - ./event_dispatcher/config.yml:/app/config.yml:ro
    networks:
      - osprey-network
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:{{ services.event_dispatcher.port | default(8020) }}/health').status==200 else 1)\""]
      interval: 10s
      timeout: 5s
      retries: 5

networks:
  osprey-network:
