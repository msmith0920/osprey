# =============================================================================
# ${config.facility.name} — .env.template
# =============================================================================
#
# COMMIT THIS FILE. It is the schema for .env.production.
#
# To bootstrap a deploy server:
#   cp .env.template .env.production
#   chmod 600 .env.production
#   $EDITOR .env.production        # fill in real secret values
#
# .env.production is gitignored. The scaffolder regenerates .env.template
# whenever facility-config.yml changes — re-run the interview and diff
# against your live .env.production to learn which new variables you need.
#
# Formatting rules (respected by scripts/deploy.sh):
#   - One KEY=VALUE per line, no surrounding quotes (podman env_file format).
#   - No inline comments after a value — put them on their own line.
#   - Multi-word values (e.g., EPICS_CA_ADDR_LIST) work because deploy.sh
#     re-quotes values before evaluating them.
# =============================================================================


# -----------------------------------------------------------------------------
# Registry + GitLab — read_registry scope at minimum. deploy.sh uses this to
# login to ${config.registry.url%%/*} and pull ${config.registry.url}/*:latest
# -----------------------------------------------------------------------------
${config.gitlab.token_env_var}=


# -----------------------------------------------------------------------------
# LLM provider key — consumed by the assistant at runtime and by CI when
# generating .env.production inside the web-terminal image.
# -----------------------------------------------------------------------------
${config.llm.api_key_env_var}=


# -----------------------------------------------------------------------------
# Registry URL mirror (so deploy.sh and any sidecar scripts can reference the
# full registry path without parsing facility-config.yml).
# -----------------------------------------------------------------------------
REGISTRY=${config.registry.url}


# -----------------------------------------------------------------------------
# Timezone — the facility timezone, applied to every container that honors $TZ.
# Matches the profile's system.timezone (set via /osprey-build-interview).
# -----------------------------------------------------------------------------
TZ=${config.facility.timezone}


# IF network.http_proxy
# -----------------------------------------------------------------------------
# Proxy — both UPPERCASE and lowercase variants are required. Python requests
# honours lowercase; Node http honours UPPERCASE; curl honours both. Setting
# only one produces intermittent "works for some tools but not others" bugs.
#
# NO_PROXY MUST include every internal service hostname that containers reach
# without going through the proxy. Docker DNS names (service names in compose)
# count as internal. Missing entries cause proxy-intercepted hangs or 502s.
# -----------------------------------------------------------------------------
HTTP_PROXY=${config.network.http_proxy}
HTTPS_PROXY=${config.network.https_proxy}
http_proxy=${config.network.http_proxy}
https_proxy=${config.network.https_proxy}
NO_PROXY=${config.network.no_proxy | join(",")}
no_proxy=${config.network.no_proxy | join(",")}
# END IF


# IF CONTROL_SYSTEM epics
# -----------------------------------------------------------------------------
# EPICS Channel Access — controls which subnets IOCs are discovered on.
# Space-separated list of broadcast or unicast addresses.
# -----------------------------------------------------------------------------
EPICS_CA_ADDR_LIST=${config.control_system.ca_addr_list}
EPICS_CA_AUTO_ADDR_LIST=NO
# END IF


# IF MODULE olog.enabled
# -----------------------------------------------------------------------------
# Electronic logbook credentials — used by the olog MCP server and (if enabled)
# by the ARIEL sync adapter that indexes logbook entries.
# -----------------------------------------------------------------------------
${config.modules.olog.username_env_var}=
${config.modules.olog.password_env_var}=
# END IF


# IF MODULE wiki_search.enabled
# -----------------------------------------------------------------------------
# Wiki / Confluence access token — bearer token scope must cover the spaces
# listed in modules.wiki_search.spaces.
# -----------------------------------------------------------------------------
${config.modules.wiki_search.token_env_var}=
# END IF


# IF MODULE event_dispatcher.enabled
# -----------------------------------------------------------------------------
# Event dispatcher — two bearer tokens.
#   - ${config.modules.event_dispatcher.token_env_var}: what external callers
#     present to /webhook/<trigger>. Distribute to CI, dashboards, cron jobs.
#   - ${config.modules.event_dispatcher.sidecar_token_env_var}: internal token
#     the dispatcher uses to reach its sidecars. Never exposed externally.
#
# Generate with:  python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# Rotate both and restart the dispatcher + every sidecar to invalidate old.
# -----------------------------------------------------------------------------
${config.modules.event_dispatcher.token_env_var}=
${config.modules.event_dispatcher.sidecar_token_env_var}=
# END IF


# IF MODULE ariel.enabled
# -----------------------------------------------------------------------------
# ARIEL Postgres DSN. Emitted for BOTH deployment modes:
#   - container: default is postgresql://ariel:ariel@ariel-postgres:5432/ariel
#                (hostname matches the compose service key)
#   - external:  full URI including credentials for the facility's existing DB
# Override POSTGRES_PASSWORD and the DSN in .env.production if the defaults
# don't fit your threat model.
# -----------------------------------------------------------------------------
ARIEL_DSN=${config.modules.ariel.dsn}
# END IF


# IF MODULE ollama.enabled
# -----------------------------------------------------------------------------
# Ollama — this facility uses an external Ollama host for embeddings.
# The URL is not secret; included here so any runtime that needs it reads
# from one place.
# -----------------------------------------------------------------------------
OLLAMA_URL=${config.modules.ollama.url}
OLLAMA_EMBEDDING_MODEL=${config.modules.ollama.embedding_model}
# END IF


# IF MODULE custom_mcp_servers.enabled
# FOR each in modules.custom_mcp_servers.servers where each.build_args
# -----------------------------------------------------------------------------
# Build-time secrets for custom MCP server: ${each.name}
# These are consumed during `docker build` via --build-arg and MUST be
# available as CI/CD project variables as well.
# -----------------------------------------------------------------------------
# FOR arg in each.build_args
${arg}=
# END FOR
# END FOR
# END IF


# IF registry.external_projects
# -----------------------------------------------------------------------------
# External project registry tokens — one deploy token per sibling project
# whose image this deploy also pulls. Create each in the external project's
# GitLab Settings → Repository → Deploy Tokens (scope: read_registry).
# -----------------------------------------------------------------------------
# FOR each in registry.external_projects
${each.token_env_var}=
# END FOR
# END IF
